{
  "name": "datahouse",
  "version": "0.2.12",
  "type": "module",
  "repository": "https://github.com/eyueldk/datahouse",
  "private": false,
  "description": "Datahouse framework",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./core": "./dist/core.mjs",
    "./client": "./dist/client.mjs"
  },
  "bin": {
    "datahouse": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@datahousejs/cli": "workspace:*",
    "@datahousejs/client": "workspace:*",
    "@datahousejs/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
