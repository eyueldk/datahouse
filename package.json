{
  "name": "@datahousejs/repo",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "3.0.0-next.1",
    "@types/bun": "latest",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "build": "turbo run build",
    "example": "cd packages/example && bun run --parallel serve studio",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "check": "turbo run check",
    "version": "changeset add && changeset version",
    "release": "bun run build && bun run check && bun run ./scripts/publish.ts",
    "release:dry": "bun run release --dry-run"
  }
}
