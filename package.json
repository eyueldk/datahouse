{
  "name": "datahouse",
  "module": "index.ts",
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "example": "cd packages/example && bun run --parallel serve studio",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "check": "turbo run check",
    "release": "turbo run build && cd packages/datahouse && bun publish"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}
